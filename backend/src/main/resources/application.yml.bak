# 后端 application.yml 配置说明

server:
  port: 8080              # 后端服务端口
  servlet:
    context-path: /api    # 上下文路径，所有接口前缀为 /api

spring:
  datasource:
    # PostgreSQL 数据库连接配置
    url: jdbc:postgresql://localhost:5432/order_manager_db
    username: postgres
    password: ${DB_PASSWORD:your_db_password}
    
  redis:
    # Redis 缓存配置
    host: localhost
    port: 6379
    database: 0

# 首次运行前请执行 sql/init.sql 初始化数据库
